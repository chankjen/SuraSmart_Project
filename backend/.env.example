# SuraSmart Backend Environment Variables
DEBUG=True
SECRET_KEY=your-secret-key-here
DATABASE_URL=postgres://user:password@localhost:5432/surasmart

# Email Services (TRD §4.3)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FALLBACK_USER=admin@surasmart.africa
DEFAULT_FROM_EMAIL=noreply@surasmart.africa

# MFA Settings (TRD §4.2)
MFA_ISSUER_NAME=SuraSmart
TOTP_SECRET_KEY=your-totp-secret-key-for-admin

# Blockchain Mocking
BLOCKCHAIN_PROVIDER_URL=http://localhost:8545
